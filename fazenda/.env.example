# Copie este arquivo para .env e preencha com seus dados reais
# cp .env.example .env

# ── Banco de dados ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=fazenda_gado
DB_CONNECTION_LIMIT=10

# ── Aplicação ───────────────────────────────────────────────
APP_PORT=3000
APP_ENV=development

# ── Upload de arquivos (boletim de abate, etc.) ─────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
